{
  "name": "@ikura-hamu/icon-generator",
  "version": "0.0.0",
  "description": "Canvas renderer for ikura-hamu icon images.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikura-hamu/icon_generator.git",
    "directory": "packages/icon-generator"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/*.js",
    "dist/*.js.map",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "~6.0.0"
  }
}
